<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme - Hiking -->
    <style name="Theme.MisLugares" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hiking_primary</item>
        <item name="colorPrimaryVariant">@color/hiking_primary_dark</item>
        <item name="colorOnPrimary">@color/hiking_text_on_primary</item>
        <item name="colorSecondary">@color/hiking_accent</item>
        <item name="colorSecondaryVariant">@color/hiking_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/hiking_background</item>
        <item name="colorSurface">@color/hiking_surface</item>
        <item name="android:statusBarColor">@color/hiking_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- No ActionBar variant (used by most activities) -->
    <style name="Theme.MisLugares.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hiking_primary</item>
        <item name="colorPrimaryVariant">@color/hiking_primary_dark</item>
        <item name="colorOnPrimary">@color/hiking_text_on_primary</item>
        <item name="colorSecondary">@color/hiking_accent</item>
        <item name="colorSecondaryVariant">@color/hiking_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/hiking_background</item>
        <item name="colorSurface">@color/hiking_surface</item>
        <item name="android:statusBarColor">@color/hiking_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.MisLugares.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.MisLugares.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- Chip style for difficulty/filter selectors -->
    <style name="Widget.MisLugares.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/hiking_surface</item>
        <item name="chipStrokeColor">@color/hiking_primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/hiking_text_primary</item>
    </style>

    <!-- Hiking card style -->
    <style name="Widget.MisLugares.DashboardCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/hiking_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Photo thumbnail shape (rounded corners) -->
    <style name="ShapeAppearance.MisLugares.Photo" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

</resources>
