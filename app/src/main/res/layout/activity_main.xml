<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hiking_background"
    tools:context=".MainActivity">

    <!-- ======== HEADER ======== -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/hiking_primary"
        android:paddingTop="40dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="4dp">

        <!-- Row: Weather (left) + Range selector (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Weather section (left) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/hiking_text_on_primary"
                    tools:text="22°C" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌡️"
                        android:textSize="16sp"
                        android:layout_marginEnd="6dp"
                        tools:text="⛅" />

                    <TextView
                        android:id="@+id/tv_condicion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando…"
                        android:textSize="13sp"
                        android:textColor="@color/hiking_text_on_primary"
                        android:alpha="0.85"
                        tools:text="Parcialmente nublado" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_ciudad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/hiking_text_on_primary"
                    android:alpha="0.65"
                    android:layout_marginTop="2dp"
                    tools:text="Monterrey, NL" />
            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="56dp"
                android:background="@color/hiking_text_on_primary"
                android:alpha="0.25"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp" />

            <!-- Range selector (right) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Radio de búsqueda"
                    android:textSize="10sp"
                    android:textColor="@color/hiking_text_on_primary"
                    android:alpha="0.7"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_range"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_5km"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="5"
                        android:textSize="11sp"
                        android:textColor="@color/hiking_text_on_primary"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        app:strokeColor="@color/hiking_text_on_primary"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_10km"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="10"
                        android:textSize="11sp"
                        android:textColor="@color/hiking_text_on_primary"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        app:strokeColor="@color/hiking_text_on_primary"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_25km"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="25"
                        android:textSize="11sp"
                        android:textColor="@color/hiking_text_on_primary"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        app:strokeColor="@color/hiking_text_on_primary"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_50km"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="50"
                        android:textSize="11sp"
                        android:textColor="@color/hiking_text_on_primary"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        app:strokeColor="@color/hiking_text_on_primary"
                        app:strokeWidth="1dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km"
                    android:textSize="10sp"
                    android:textColor="@color/hiking_text_on_primary"
                    android:alpha="0.6"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- App title bar with menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mis Lugares"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/hiking_text_on_primary"
                android:alpha="0.9"
                android:letterSpacing="0.05" />

            <ImageButton
                android:id="@+id/btn_mapa"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_mapmode"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Ver mapa"
                app:tint="@color/hiking_text_on_primary" />

            <ImageButton
                android:id="@+id/btn_preferencias"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Preferencias"
                android:layout_marginStart="4dp"
                app:tint="@color/hiking_text_on_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- ======== SCROLLABLE BODY ======== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="188dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="80dp">

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explora tu entorno"
                android:textSize="13sp"
                android:textColor="@color/hiking_text_secondary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="16dp" />

            <!-- Row 1: Cerca de Mí + Por Visitar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Card 1: Cerca de Mí -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_cerca"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/hiking_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="🏔️"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_bg_green"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cerca de Mí"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/hiking_text_primary"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lugares de interés"
                            android:textSize="11sp"
                            android:textColor="@color/hiking_text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2: Por Visitar -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_visitar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/hiking_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="📍"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_bg_orange"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Por Visitar"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/hiking_text_primary"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lista de pendientes"
                            android:textSize="11sp"
                            android:textColor="@color/hiking_text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Row 2: Nivel + Senderismo/Camping -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="horizontal">

                <!-- Card 3: Nivel -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_nivel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/hiking_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="⛰️"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_bg_blue"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nivel"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/hiking_text_primary"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Filtra por dificultad"
                            android:textSize="11sp"
                            android:textColor="@color/hiking_text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 4: Senderismo / Camping -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_senderismo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/hiking_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="🏕️"
                            android:textSize="26sp"
                            android:gravity="center"
                            android:background="@drawable/circle_bg_brown"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Senderismo"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/hiking_text_primary"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="y Camping"
                            android:textSize="11sp"
                            android:textColor="@color/hiking_text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Agregar lugar"
        app:backgroundTint="@color/hiking_primary"
        app:tint="@color/hiking_text_on_primary"
        app:srcCompat="@android:drawable/ic_input_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
