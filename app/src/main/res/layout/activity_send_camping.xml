<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hiking_background"
    tools:context=".SendCampingActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.MisLugares.AppBarOverlay">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_sendcamp"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/hiking_primary"
            app:navigationIconTint="@color/white"
            app:titleTextColor="@color/white"
            app:title="Senderismo y Camping" />

        <!-- Type filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/hiking_primary"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_tipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_todos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todos"
                    android:textColor="@color/white"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/hiking_primary_light"
                    app:chipStrokeColor="@color/white"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_senderismo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥾  Senderismo"
                    android:textColor="@color/white"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/hiking_primary_light"
                    app:chipStrokeColor="@color/white"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_camping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏕️  Camping"
                    android:textColor="@color/white"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/hiking_primary_light"
                    app:chipStrokeColor="@color/white"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/white" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏕️"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No hay lugares de este tipo.\nAgrega uno con el botón +"
            android:textSize="15sp"
            android:textColor="@color/hiking_text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_sendcamp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_sendcamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Agregar lugar"
        app:backgroundTint="@color/hiking_primary"
        app:tint="@color/white"
        app:srcCompat="@android:drawable/ic_input_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
